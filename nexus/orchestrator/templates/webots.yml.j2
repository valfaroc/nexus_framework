nexus-sim:
  build:
    context: .
    dockerfile: docker/Dockerfile.webots
  image: nexus/webots:R2023b
  container_name: nexus_webots
  environment:
    - DISPLAY=${DISPLAY}
    - WEBOTS_HOME=/usr/local/webots
    - ROS_DOMAIN_ID=0
    - XAUTHORITY=/root/.Xauthority
  volumes:
    - /tmp/.X11-unix:/tmp/.X11-unix:rw
    - ${HOME}/.Xauthority:/root/.Xauthority:ro
    - ./simulators/webots/worlds:/nexus/worlds
    - .:/nexus
  networks:
    - nexus_net
  command: bash -c "source /opt/ros/humble/setup.bash && echo '[nexus_webots] Starting Webots...' && webots /nexus/worlds/simple_road.wbt & sleep 10 && echo '[nexus_webots] Starting extern controller' && python3 /nexus/simulators/webots/extern_controller.py"
