nexus-sim:
  build:
    context: .
    dockerfile: docker/Dockerfile.webots
  image: nexus/webots:R2023b
  container_name: nexus_webots
  environment:
    - DISPLAY=${DISPLAY}
    - WEBOTS_HOME=/usr/local/webots
    - ROS_DOMAIN_ID=0
    - XAUTHORITY=/root/.Xauthority
  volumes:
    - /tmp/.X11-unix:/tmp/.X11-unix:rw
    - ${HOME}/.Xauthority:/root/.Xauthority:ro
    - ./simulators/webots/worlds:/nexus/worlds:ro
    - .:/nexus
  networks:
    - nexus_net
  command: >
    bash -c "source /opt/ros/humble/setup.bash &&
             webots /nexus/worlds/simple_road.wbt &
             sleep 5 &&
             echo '✅ Webots ready' &&
             python3 /nexus/simulators/webots/extern_controller.py"
