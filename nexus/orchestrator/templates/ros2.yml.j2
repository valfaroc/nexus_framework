nexus-ros2:
  build:
    context: .
    dockerfile: docker/Dockerfile.ros2
  image: nexus/ros2:humble
  container_name: nexus_ros2
  environment:
    - DISPLAY=${DISPLAY}
    - ROS_DOMAIN_ID=0
    - PYTHONPATH=/nexus
    - NEXUS_CONFIG={{ config_path | default('/nexus/nexus.yaml') }}
  volumes:
    - /tmp/.X11-unix:/tmp/.X11-unix:rw
    {% if config.simulator.type == "carla" %}- rviz_shared_configs:/root/.rviz2{% endif %}
    - .:/nexus
  working_dir: /nexus
  depends_on:
    - nexus-sim
  networks:
    - nexus_net
  command: >
    bash -c "source /opt/ros/humble/setup.bash &&
             echo '✅ Nexus ROS2 container ready' &&
             python3 -m nexus.cli.main run --config ${NEXUS_CONFIG}"
